# Variables de entorno — Filatelia Peruana
# Copia este archivo a .env y rellena los valores

# ---- Base de Datos ----
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/filateliaperuana?schema=public"

# ---- NextAuth ----
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genera-un-secreto-aleatorio-aqui"

# ---- Almacenamiento de imágenes ----
# En fase 1 usa la carpeta /public. Para s3/Cloudinary, cambia STORAGE_DRIVER
STORAGE_DRIVER="local"
# STORAGE_URL="https://cdn.filateliaperuana.com" # Para producción con CDN

# ---- Límites de subida ----
MAX_FILE_SIZE_MB=5

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Filatelia Peruana"
